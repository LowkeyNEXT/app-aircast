#!/command/with-contenv bashio
# ==============================================================================
# Take down the S6 supervision tree when bridge fails
# ==============================================================================
declare exit_code=${1}
declare signal=${2}

if [[ "${exit_code}" -ne 0 ]] && [[ "${exit_code}" -ne 256 ]]; then
    bashio::log.warning \
        "Bridge exited with code ${exit_code} (signal ${signal})"
    if [[ "${signal}" -eq 15 ]]; then
        exec /run/s6/basedir/bin/halt
    fi
fi
